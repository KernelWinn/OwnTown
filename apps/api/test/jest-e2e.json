{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": { "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.json" }] },
  "testEnvironment": "node",
  "testTimeout": 15000,
  "moduleNameMapper": {
    "^@owntown/utils$": "<rootDir>/../../packages/utils/src/index.ts",
    "^@owntown/types$": "<rootDir>/../../packages/types/src/index.ts"
  }
}
